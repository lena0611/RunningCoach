VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Edge Function secrets, set with:
# supabase secrets set OPENAI_API_KEY=...
# supabase secrets set OPENAI_MODEL=gpt-5.4-mini
# supabase secrets set APP_SESSION_HMAC_SECRET=...
# supabase secrets set APP_SECURITY_MODE=allowlist
# supabase secrets set PACELAB_ALLOWED_EMAILS=user@example.com
# supabase secrets set COACH_RUN_RATE_LIMIT_PER_HOUR=12
#
# Optional production hardening when paid Apple Developer DeviceCheck keys are available:
# supabase secrets set APP_SECURITY_MODE=devicecheck
# supabase secrets set APPLE_TEAM_ID=...
# supabase secrets set APPLE_DEVICECHECK_KEY_ID=...
# supabase secrets set APPLE_DEVICECHECK_PRIVATE_KEY="$(cat AuthKey_XXXXXXXXXX.p8)"
# supabase secrets set APPLE_DEVICECHECK_ENVIRONMENT=production
#
# Local Edge Function development only:
# supabase secrets set APP_SECURITY_MODE=development
# supabase secrets set APP_SECURITY_DEVELOPMENT_TOKEN=...
